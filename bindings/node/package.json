{
  "name": "wickra-genome",
  "version": "0.1.0",
  "description": "A vector database of the market: every asset a live vector over the streaming indicators, with similarity, clustering and anomaly detection. Node.js bindings powered by Rust.",
  "author": "kingchenc <support@wickra.org>",
  "main": "index.js",
  "types": "index.d.ts",
  "license": "MIT OR Apache-2.0",
  "keywords": [
    "trading",
    "indicators",
    "vector-database",
    "similarity",
    "clustering",
    "anomaly-detection",
    "napi"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/wickra-lib/wickra-genome"
  },
  "bugs": {
    "url": "https://github.com/wickra-lib/wickra-genome/issues"
  },
  "homepage": "https://github.com/wickra-lib/wickra-genome",
  "files": [
    "index.js",
    "index.d.ts",
    "npm",
    "*.node"
  ],
  "napi": {
    "name": "wickra-genome",
    "triples": {
      "defaults": false,
      "additional": [
        "x86_64-unknown-linux-gnu",
        "aarch64-unknown-linux-gnu",
        "x86_64-apple-darwin",
        "aarch64-apple-darwin",
        "x86_64-pc-windows-msvc",
        "aarch64-pc-windows-msvc"
      ]
    }
  },
  "engines": {
    "node": ">= 22"
  },
  "optionalDependencies": {
    "wickra-genome-linux-x64-gnu": "0.1.0",
    "wickra-genome-linux-arm64-gnu": "0.1.0",
    "wickra-genome-darwin-x64": "0.1.0",
    "wickra-genome-darwin-arm64": "0.1.0",
    "wickra-genome-win32-x64-msvc": "0.1.0",
    "wickra-genome-win32-arm64-msvc": "0.1.0"
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "artifacts": "napi artifacts",
    "version": "napi version",
    "test": "node --test"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.7.2"
  }
}
